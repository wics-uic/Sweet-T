---
export const prerender = false;
import Layout from "../layouts/layout.astro";
import NavBar from "../components/navbar.astro";
import OrderAccordion from "../components/OrderAccordion.astro";

// Mock orders data with placeholders - replace with actual data fetching later
const orders = [
  {
    customerName: "Name",
    orderItems: "No items yet",
    pickupTime: "Pickup time TBD",
    status: "pending" as const,
  },
  // You can add more placeholder orders or leave this array empty
];

// Example of what real orders will look like when implemented:
// const orders = [
//   {
//     customerName: "Maria Rodriguez",
//     orderItems: "1x Custom Birthday Cake",
//     pickupTime: "Fri, Nov 1 • 3:00pm",
//     status: "ready" as const,
//     itemStatus: "Due today"
//   },
// ];
---

<Layout title="Your Orders - Sweet T">
  <NavBar />
  <main class="max-w-4xl mx-auto p-6 min-h-screen">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Your Orders</h1>
      <p class="text-gray-600">View and manage your Sweet T orders</p>
    </div>
    
    {orders.length > 0 ? (
      <div class="space-y-4">
        {orders.map(order => (
          <OrderAccordion {...order} />
        ))}
      </div>
    ) : (
      <div class="bg-gray-50 rounded-lg p-12 text-center">
        <svg class="w-16 h-16 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">No orders yet</h3>
        <p class="text-gray-600 mb-6">Start shopping to see your orders here!</p>
        <a href="/" class="inline-block bg-pink-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-pink-600 transition-colors">
          Shop Treats
        </a>
      </div>
    )}
  </main>
</Layout>